[
  {
    "id": 1,
    "title": "Font Families",
    "description": "Add a .mono CSS rule with Courier New as the font family (with fallbacks).",
    "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n<style>\n.serif {\n  /* Times New Roman with fallbacks */\n}\n\n.sans {\n  /* Arial with fallbacks */\n}\n\n/* add .mono rule here */\n</style>\n</head>\n<body>\n\n<p class=\"serif\">This is a serif font (Times New Roman).</p>\n<p class=\"sans\">This is a sans-serif font (Arial).</p>\n<p class=\"mono\">This is a monospace font (Courier New).</p>\n\n</body>\n</html>",
    "solutionCode": "<!DOCTYPE html>\n<html>\n<head>\n<style>\n.serif {\n  font-family: \"Times New Roman\", Times, serif;\n}\n\n.sans {\n  font-family: Arial, Helvetica, sans-serif;\n}\n\n.mono {\n  font-family: \"Courier New\", Courier, monospace;\n}\n</style>\n</head>\n<body>\n\n<p class=\"serif\">This is a serif font (Times New Roman).</p>\n<p class=\"sans\">This is a sans-serif font (Arial).</p>\n<p class=\"mono\">This is a monospace font (Courier New).</p>\n\n</body>\n</html>",
