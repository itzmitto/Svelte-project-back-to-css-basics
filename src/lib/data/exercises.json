  "description": "Complete the CSS to style paragraphs using an element selector, a class selector, and an ID selector.",
  "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n<style>\n/* element selector */\n/* class selector */\n/* id selector */\n</style>\n</head>\n<body>\n<p id=\"intro\">Welcome to CSS selectors.</p>\n<p>This is a normal paragraph.</p>\n<p class=\"highlight\">This paragraph is highlighted.</p>\n</body>\n</html>",
  "solutionCode": "<!DOCTYPE html>\n<html>\n<head>\n<style>\np {\n  color: dimgray;\n}\n.highlight {\n  background-color: yellow;\n}\n#intro {\n  font-size: 20px;\n}\n</style>\n</head>\n<body>\n<p id=\"intro\">Welcome to CSS selectors.</p>\n<p>This is a normal paragraph.</p>\n<p class=\"highlight\">This paragraph is highlighted.</p>\n</body>\n</html>",
  "checks": [
    {
      "description": "Uses element selector for paragraphs",
      "pattern": "p\\s*\\{"
    },
    {
      "description": "Sets paragraph color to dimgray",
      "pattern": "color\\s*:\\s*dimgray"
    },
    {
      "description": "Uses class selector for highlight",
      "pattern": "\\.highlight\\s*\\{"
    },
    {
      "description": "Sets highlight background to yellow",
      "pattern": "background-color\\s*:\\s*yellow"
    },
    {
      "description": "Uses ID selector for intro",
      "pattern": "#intro\\s*\\{"
    },
    {
      "description": "Sets intro font size to 20px",
      "pattern": "font-size\\s*:\\s*20px"
    }
  ]
},
