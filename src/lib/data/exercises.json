 {
  "id": 4,
  "title": "Styled Table",
  "description": "Complete the CSS to create a styled table with borders, padding, a green header, and alternating row colors.",
  "starterCode": "<!DOCTYPE html>\n<html>\n<head>\n<style>\ntable {\n  /* border-collapse, width */\n}\n\nth, td {\n  /* border, padding */\n}\n\nth {\n  /* background-color, color, text-align */\n}\n\ntr:nth-child(even) {\n  /* background-color */\n}\n</style>\n</head>\n<body>\n\n<table>\n  <tr><th>Name</th><th>Age</th><th>City</th></tr>\n  <tr><td>Alice</td><td>28</td><td>London</td></tr>\n  <tr><td>Bob</td><td>34</td><td>Paris</td></tr>\n  <tr><td>Carol</td><td>22</td><td>Berlin</td></tr>\n  <tr><td>Dave</td><td>45</td><td>Madrid</td></tr>\n</table>\n\n</body>\n</html>",
  "solutionCode": "<!DOCTYPE html>\n<html>\n<head>\n<style>\ntable {\n  border-collapse: collapse;\n  width: 100%;\n}\n\nth, td {\n  border: 1px solid lightgray;\n  padding: 12px;\n}\n\nth {\n  background-color: #04AA6D;\n  color: white;\n  text-align: left;\n}\n\ntr:nth-child(even) {\n  background-color: #f2f2f2;\n}\n</style>\n</head>\n<body>\n\n<table>\n  <tr><th>Name</th><th>Age</th><th>City</th></tr>\n  <tr><td>Alice</td><td>28</td><td>London</td></tr>\n  <tr><td>Bob</td><td>34</td><td>Paris</td></tr>\n  <tr><td>Carol</td><td>22</td><td>Berlin</td></tr>\n  <tr><td>Dave</td><td>45</td><td>Madrid</td></tr>\n</table>\n\n</body>\n</html>",
  "checks": [
    {
      "description": "Uses border-collapse",
      "pattern": "border-collapse\\s*:\\s*collapse"
    },
    {
      "description": "Sets table width to 100%",
      "pattern": "width\\s*:\\s*100%"
    },
    {
      "description": "Adds borders to table cells",
      "pattern": "border\\s*:\\s*1px\\s+solid"
    },
    {
      "description": "Adds padding to table cells",
      "pattern": "padding\\s*:\\s*12px"
    },
    {
      "description": "Styles table header background",
      "pattern": "background-color\\s*:\\s*#04AA6D"
    },
    {
      "description": "Styles alternating rows",
      "pattern": "nth-child\\(even\\)"
    }
  ]
},
{
